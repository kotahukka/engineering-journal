# --------------------------------------------------
# EditorConfig helps maintain consistent formatting
# across editors and IDEs
# https://editorconfig.org
# --------------------------------------------------

root = true

# --------------------------------------------------
# Default settings for all files
# --------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# --------------------------------------------------
# Markdown
# --------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# --------------------------------------------------
# YAML (GitHub Actions, mkdocs.yml)
# --------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# --------------------------------------------------
# Python
# --------------------------------------------------
[*.py]
indent_size = 4

# --------------------------------------------------
# Shell scripts
# --------------------------------------------------
[*.sh]
indent_size = 2

# --------------------------------------------------
# JSON
# --------------------------------------------------
[*.json]
indent_size = 2
